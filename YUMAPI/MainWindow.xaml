<Window x:Class="YUMAPI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Yum! - Gourmet Studio"
        Height="900" Width="1300"
        WindowStartupLocation="CenterScreen"
        Background="#111111">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="360"/>
            <!-- ListeView -->
            <ColumnDefinition Width="*"/>
            <!-- DetailView -->
        </Grid.ColumnDefinitions>

        <!-- Colonne gauche : liste des recettes -->
        <Grid x:Name="ContainerListe" Grid.Column="0"/>

        <!-- Colonne droite : détail de la recette -->
        <Grid x:Name="ContainerDetail" Grid.Column="1"/>
    </Grid>

</Window>
