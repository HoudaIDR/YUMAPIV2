<UserControl x:Class="YUMAPI.Views.ProfilView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d">

    <!-- Fond noir semi-transparent qui bloque le reste -->
    <Grid Background="#BB000000">

        <!-- Panneau profil centré -->
        <Border Width="460"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="#1A1A1A"
                CornerRadius="16"
                Padding="0">
            <Border.Effect>
                <DropShadowEffect Color="#000000" BlurRadius="40" Opacity="0.8" ShadowDepth="0"/>
            </Border.Effect>

            <StackPanel>

                <!-- EN-TÊTE avec avatar et bouton fermer -->
                <Grid Margin="28,28,28,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Avatar grand -->
                    <Border Grid.Column="0"
                            x:Name="AvatarBorder"
                            Background="#FF6B35"
                            Width="64" Height="64"
                            CornerRadius="32">
                        <TextBlock x:Name="TxtAvatarGrand"
                                   Text="?"
                                   Foreground="White"
                                   FontSize="26"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>

                    <!-- Nom + date -->
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="16,0,0,0">
                        <TextBlock x:Name="TxtNomProfil"
                                   Text="Utilisateur"
                                   Foreground="White"
                                   FontSize="20"
                                   FontWeight="Bold"/>
                        <TextBlock x:Name="TxtDateCreation"
                                   Text="Membre depuis ..."
                                   Foreground="#777777"
                                   FontSize="12"
                                   Margin="0,3,0,0"/>
                    </StackPanel>

                    <!-- Bouton fermer -->
                    <Border Grid.Column="2"
                            Width="34" Height="34"
                            CornerRadius="10"
                            Background="#2A2A2A"
                            Cursor="Hand"
                            VerticalAlignment="Top"
                            MouseDown="BtnFermer_Click">
                        <TextBlock Text="✕"
                                   Foreground="#888888"
                                   FontSize="14"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                </Grid>

                <!-- SÉPARATEUR -->
                <Border Height="1" Background="#2A2A2A" Margin="0,22,0,22"/>

                <!-- STATS : favoris + dernière recette -->
                <StackPanel Margin="28,0,28,0">

                    <!-- Nombre de favoris -->
                    <Border Background="#222222" CornerRadius="12"
                            Padding="16,14" Margin="0,0,0,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="❤️"
                                       FontSize="20" VerticalAlignment="Center"
                                       Margin="0,0,14,0"/>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="Mes favoris"
                                           Foreground="White" FontSize="13"
                                           FontWeight="SemiBold"/>
                                <TextBlock x:Name="TxtNbFavoris"
                                           Text="0 recette"
                                           Foreground="#777777" FontSize="11"
                                           Margin="0,2,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Dernière recette consultée -->
                    <Border Background="#222222" CornerRadius="12"
                            Padding="16,14" Margin="0,0,0,22">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="🕐"
                                       FontSize="20" VerticalAlignment="Center"
                                       Margin="0,0,14,0"/>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="Dernière recette consultée"
                                           Foreground="White" FontSize="13"
                                           FontWeight="SemiBold"/>
                                <TextBlock x:Name="TxtDerniereRecette"
                                           Text="Aucune recette consultée"
                                           Foreground="#777777" FontSize="11"
                                           Margin="0,2,0,0"
                                           TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                </StackPanel>

                <!-- SÉPARATEUR -->
                <Border Height="1" Background="#2A2A2A" Margin="0,0,0,22"/>

                <!-- SÉLECTEUR DE THÈME -->
                <StackPanel Margin="28,0,28,28">

                    <TextBlock Text="🎨  Couleur du thème"
                               Foreground="White"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Margin="0,0,0,14"/>

                    <!-- Les 6 cercles de couleur -->
                    <StackPanel Orientation="Horizontal">

                        <!-- Orange (défaut) -->
                        <Border x:Name="CerclOrange"
                                Width="40" Height="40" CornerRadius="20"
                                Background="#FF6B35" Cursor="Hand"
                                Margin="0,0,12,0"
                                MouseDown="BtnCouleur_Click"
                                Tag="#FF6B35">
                            <Border.Effect>
                                <DropShadowEffect Color="#FF6B35" BlurRadius="10" Opacity="0.6" ShadowDepth="0"/>
                            </Border.Effect>
                        </Border>

                        <!-- Rose -->
                        <Border x:Name="CerclRose"
                                Width="40" Height="40" CornerRadius="20"
                                Background="#E91E8C" Cursor="Hand"
                                Margin="0,0,12,0"
                                MouseDown="BtnCouleur_Click"
                                Tag="#E91E8C"/>

                        <!-- Rouge -->
                        <Border x:Name="CerclRouge"
                                Width="40" Height="40" CornerRadius="20"
                                Background="#E53935" Cursor="Hand"
                                Margin="0,0,12,0"
                                MouseDown="BtnCouleur_Click"
                                Tag="#E53935"/>

                        <!-- Bleu -->
                        <Border x:Name="CerclBleu"
                                Width="40" Height="40" CornerRadius="20"
                                Background="#1E88E5" Cursor="Hand"
                                Margin="0,0,12,0"
                                MouseDown="BtnCouleur_Click"
                                Tag="#1E88E5"/>

                        <!-- Vert -->
                        <Border x:Name="CerclVert"
                                Width="40" Height="40" CornerRadius="20"
                                Background="#43A047" Cursor="Hand"
                                Margin="0,0,12,0"
                                MouseDown="BtnCouleur_Click"
                                Tag="#43A047"/>

                        <!-- Violet -->
                        <Border x:Name="CerclViolet"
                                Width="40" Height="40" CornerRadius="20"
                                Background="#8E24AA" Cursor="Hand"
                                MouseDown="BtnCouleur_Click"
                                Tag="#8E24AA"/>

                    </StackPanel>

                    <!-- Indicateur de la couleur active -->
                    <TextBlock x:Name="TxtCouleurActive"
                               Text="Orange (par défaut)"
                               Foreground="#777777"
                               FontSize="11"
                               Margin="0,10,0,0"/>

                </StackPanel>

            </StackPanel>
        </Border>

    </Grid>
</UserControl>
