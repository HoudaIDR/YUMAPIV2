<UserControl x:Class="YUMAPI.Views.BienvenueView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d">

    <!-- Fond noir semi-transparent qui couvre toute la fenêtre -->
    <Grid Background="#BB000000">

        <!-- Carte centrée -->
        <Border Width="480"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="#1A1A1A"
                CornerRadius="16"
                Padding="40,35,40,35">
            <Border.Effect>
                <DropShadowEffect Color="#000000" BlurRadius="40" Opacity="0.7" ShadowDepth="0"/>
            </Border.Effect>

            <StackPanel>

                <!-- Emoji décoratif -->
                <TextBlock Text="🍽️"
                           FontSize="48"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,16"/>

                <!-- Message bienvenue avec le prénom -->
                <TextBlock x:Name="TxtBienvenue"
                           Text="Bienvenue !"
                           FontSize="28"
                           FontWeight="Bold"
                           Foreground="White"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"
                           Margin="0,0,0,14"/>

                <!-- Proposition générée (texte mis à jour après appel API) -->
                <TextBlock x:Name="TxtProposition"
                           Text="⏳ Recherche d'une recette..."
                           FontSize="16"
                           Foreground="#CCCCCC"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"
                           TextWrapping="Wrap"
                           Margin="0,0,0,30"/>

                <!-- Les 2 boutons -->
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center">

                    <!-- Bouton OUI - orange -->
                    <Border x:Name="BtnOui"
                            Width="175"
                            Height="48"
                            CornerRadius="8"
                            Background="#FF6B35"
                            Cursor="Hand"
                            Margin="0,0,12,0"
                            MouseDown="BtnOui_Click">
                        <Border.Effect>
                            <DropShadowEffect Color="#FF6B35" BlurRadius="14" Opacity="0.5" ShadowDepth="0"/>
                        </Border.Effect>
                        <TextBlock Text="Oui ! J'y vais 🚀"
                                   FontSize="14"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>

                    <!-- Bouton NON - gris foncé -->
                    <Border x:Name="BtnNon"
                            Width="175"
                            Height="48"
                            CornerRadius="8"
                            Background="#2E2E2E"
                            Cursor="Hand"
                            MouseDown="BtnNon_Click">
                        <TextBlock Text="Non merci"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="#AAAAAA"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>

                </StackPanel>

            </StackPanel>
        </Border>

    </Grid>
</UserControl>
