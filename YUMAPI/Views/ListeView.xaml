<UserControl x:Class="YUMAPI.Views.ListeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="900" d:DesignWidth="360">

    <Border Background="#1A1A1A" BorderBrush="#2A2A2A" BorderThickness="0,0,1,0">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- LOGO -->
            <Grid Grid.Row="0" Margin="20,30,20,25">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Background="#FF6B35" Width="48" Height="48"
                        CornerRadius="24" Margin="0,0,12,0">
                    <TextBlock Text="🍴" FontSize="22"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>

                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="Yum!" Foreground="White" FontSize="26" FontWeight="Black"/>
                    <TextBlock Text="GOURMET STUDIO" Foreground="#666666" FontSize="9" FontWeight="SemiBold"/>
                </StackPanel>

                <!-- Bouton ❤ en haut : affiche les favoris -->
                <Border Grid.Column="2"
                        x:Name="BordureFavorisHaut"
                        Background="#FF6B35" Width="36" Height="36"
                        CornerRadius="18" VerticalAlignment="Center"
                        Cursor="Hand"
                        MouseDown="BtnFavorisHaut_Click">
                    <TextBlock x:Name="BtnFavorisHaut"
                               Text="🤍" FontSize="15"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>
            </Grid>

            <!-- BARRE DE RECHERCHE -->
            <Border Grid.Row="1" Margin="20,0,20,16"
                    Background="#242424" CornerRadius="12"
                    BorderBrush="#333333" BorderThickness="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="🔍"
                               FontSize="15" Foreground="#666666"
                               VerticalAlignment="Center" Margin="14,0,0,0"
                               IsHitTestVisible="False"/>

                    <TextBox x:Name="SearchBox"
                             Grid.Column="1"
                             Background="Transparent" Foreground="White"
                             BorderThickness="0" FontSize="13"
                             Padding="10,12" VerticalContentAlignment="Center"
                             CaretBrush="White"
                             KeyDown="SearchBox_KeyDown"
                             TextChanged="SearchBox_TextChanged"/>

                    <Button x:Name="BtnRechercher"
                            Grid.Column="2"
                            Content="→" Width="36" Height="36" Margin="4"
                            Background="#FF6B35" Foreground="White"
                            FontSize="16" FontWeight="Bold" BorderThickness="0"
                            Click="BtnRechercher_Click">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="10"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </Grid>
            </Border>

            <!-- BOUTON TOUTES LES RECETTES -->
            <Border Grid.Row="2" Margin="20,0,20,16"
                    Background="#242424" CornerRadius="12"
                    BorderBrush="#333333" BorderThickness="1">
                <Button x:Name="BtnToutesLesRecettes"
                        Background="Transparent" Foreground="White"
                        BorderThickness="0" FontSize="13" FontWeight="SemiBold"
                        Padding="14,12" HorizontalContentAlignment="Left"
                        Click="BtnToutesLesRecettes_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    CornerRadius="12" Padding="{TemplateBinding Padding}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="🍽️"
                                               FontSize="15" VerticalAlignment="Center"
                                               Margin="0,0,10,0"/>
                                    <TextBlock Grid.Column="1" Text="Toutes les recettes"
                                               Foreground="White" FontSize="13"
                                               FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    <Border Grid.Column="2" Background="#FF6B35"
                                            CornerRadius="8" Padding="8,4">
                                        <TextBlock Text="ALL" Foreground="White"
                                                   FontSize="10" FontWeight="Bold"/>
                                    </Border>
                                </Grid>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#2E2E2E"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Border>

            <!-- SÉLECTEUR DE LANGUE -->
            <Border Grid.Row="3" Margin="20,0,20,20"
                    Background="#242424" CornerRadius="10"
                    BorderBrush="#333333" BorderThickness="1">
                <ComboBox x:Name="LanguageSelector"
                          Background="Transparent" Foreground="Black"
                          BorderThickness="0" FontSize="13" Padding="12,10">
                    <ComboBoxItem Content="🇺🇸  English (US)" Tag="en" IsSelected="True"/>
                    <ComboBoxItem Content="🇫🇷  Français"     Tag="fr"/>
                    <ComboBoxItem Content="🇪🇸  Español"      Tag="es"/>
                </ComboBox>
            </Border>

            <!-- TITRE SECTION -->
            <TextBlock x:Name="TxtSectionTitle" Grid.Row="4"
                       Text="FEATURED COLLECTION"
                       Foreground="#555555" FontSize="10" FontWeight="SemiBold"
                       Margin="20,0,20,12"/>

            <!-- LISTE DES RECETTES -->
            <ListView x:Name="ListeRecettes" Grid.Row="5"
                      Margin="12,0,12,12"
                      Background="Transparent" BorderThickness="0"
                      SelectionChanged="ListeRecettes_SelectionChanged">
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="Background"              Value="Transparent"/>
                        <Setter Property="BorderThickness"         Value="0"/>
                        <Setter Property="Padding"                 Value="0"/>
                        <Setter Property="Margin"                  Value="0,0,0,6"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    </Style>
                </ListView.ItemContainerStyle>
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Border Background="#222222" CornerRadius="12" Padding="12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="52"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Miniature -->
                                <Border Grid.Column="0" Width="52" Height="52"
                                        CornerRadius="10" ClipToBounds="True">
                                    <Image Source="{Binding Thumb}" Stretch="UniformToFill"/>
                                </Border>

                                <!-- Nom -->
                                <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Title}"
                                               Foreground="White" FontSize="13"
                                               FontWeight="SemiBold"
                                               TextTrimming="CharacterEllipsis"/>
                                </StackPanel>

                                <!-- Bouton ❤ avec rond orange -->
                                <Border Grid.Column="2"
                                        Background="#FF6B35" Width="32" Height="32"
                                        CornerRadius="16" Margin="8,0,0,0"
                                        Cursor="Hand"
                                        Tag="{Binding}"
                                        MouseDown="BtnCoeur_Click">
                                    <TextBlock Text="🤍" FontSize="14"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               IsHitTestVisible="False"/>
                                </Border>

                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

        </Grid>
    </Border>
</UserControl>