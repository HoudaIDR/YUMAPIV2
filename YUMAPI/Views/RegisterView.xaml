<UserControl x:Class="YUMAPI.Views.RegisterView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="900" d:DesignWidth="1300"
             Background="#111111">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.2*"/>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>

        <!-- IMAGE GAUCHE -->
        <Border Grid.Column="0" Background="#1A1A1A">
            <Grid>
                <Border Background="#FF6B3522"/>
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="🍴" FontSize="100"
                               HorizontalAlignment="Center" Margin="0,0,0,30"/>
                    <TextBlock Text="Yum!" Foreground="White" FontSize="64"
                               FontWeight="Black" HorizontalAlignment="Center"/>
                    <TextBlock Text="GOURMET STUDIO" Foreground="#FF6B35"
                               FontSize="16" FontWeight="SemiBold"
                               HorizontalAlignment="Center" Margin="0,10,0,0"/>
                    <TextBlock x:Name="TxtSousTitreGauche"
                               Text="Découvrez des milliers de recettes"
                               Foreground="#666666" FontSize="14"
                               HorizontalAlignment="Center" Margin="0,20,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- FORMULAIRE INSCRIPTION -->
        <Border Grid.Column="1" Background="#161616">
            <StackPanel VerticalAlignment="Center" Margin="60,0">

                <TextBlock x:Name="TxtTitre" Text="Créer un compte"
                           Foreground="White" FontSize="36" FontWeight="Black"
                           Margin="0,0,0,8"/>
                <TextBlock x:Name="TxtSousTitre" Text="Rejoignez la communauté Yum! 🎉"
                           Foreground="#666666" FontSize="14" Margin="0,0,0,40"/>

                <TextBlock x:Name="TxtLabelUsername" Text="Nom d'utilisateur"
                           Foreground="#999999" FontSize="12" FontWeight="SemiBold"
                           Margin="0,0,0,8"/>
                <Border Background="#222222" CornerRadius="10"
                        BorderBrush="#333333" BorderThickness="1" Margin="0,0,0,20">
                    <TextBox x:Name="UsernameBox" Background="Transparent"
                             Foreground="White" BorderThickness="0" FontSize="14"
                             Padding="16,14" CaretBrush="White"/>
                </Border>

                <TextBlock x:Name="TxtLabelPassword" Text="Mot de passe"
                           Foreground="#999999" FontSize="12" FontWeight="SemiBold"
                           Margin="0,0,0,8"/>
                <Border Background="#222222" CornerRadius="10"
                        BorderBrush="#333333" BorderThickness="1" Margin="0,0,0,20">
                    <PasswordBox x:Name="PasswordBox" Background="Transparent"
                                 Foreground="White" BorderThickness="0"
                                 FontSize="14" Padding="16,14"/>
                </Border>

                <TextBlock x:Name="TxtLabelConfirm" Text="Confirmer le mot de passe"
                           Foreground="#999999" FontSize="12" FontWeight="SemiBold"
                           Margin="0,0,0,8"/>
                <Border Background="#222222" CornerRadius="10"
                        BorderBrush="#333333" BorderThickness="1" Margin="0,0,0,8">
                    <PasswordBox x:Name="ConfirmPasswordBox" Background="Transparent"
                                 Foreground="White" BorderThickness="0"
                                 FontSize="14" Padding="16,14"/>
                </Border>

                <TextBlock x:Name="MessageRetour" FontSize="12" Margin="0,0,0,20"
                           Visibility="Collapsed" TextWrapping="Wrap"/>

                <Button x:Name="BtnInscrire" Content="Créer mon compte"
                        Height="50" FontSize="16" FontWeight="Bold"
                        Background="#FF6B35" Foreground="White"
                        BorderThickness="0" Margin="0,0,0,20"
                        Click="BtnInscrire_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="10"/>
                        </Style>
                    </Button.Resources>
                </Button>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock x:Name="TxtDejaCompte" Text="Déjà un compte ? "
                               Foreground="#666666" FontSize="13"/>
                    <TextBlock x:Name="LienConnexion" Text="Se connecter"
                               Foreground="#FF6B35" FontSize="13" FontWeight="Bold"
                               Cursor="Hand" MouseLeftButtonDown="LienConnexion_Click"/>
                </StackPanel>

            </StackPanel>
        </Border>
    </Grid>
</UserControl>
