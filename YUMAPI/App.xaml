<Application x:Class="YUMAPI.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:YUMAPI"
             StartupUri="MainWindow.xaml">
    <Application.Resources>

        <!-- ══════════════════════════════════════════════════════════ -->
        <!--  SCROLLBAR DESIGN - Fine, orange, arrondie                -->
        <!-- ══════════════════════════════════════════════════════════ -->

        <!-- Bouton répétiteur (flèches haut/bas) → invisibles -->
        <Style x:Key="ScrollBarRepeatButton" TargetType="RepeatButton">
            <Setter Property="Background"   Value="Transparent"/>
            <Setter Property="Focusable"    Value="False"/>
            <Setter Property="IsTabStop"    Value="False"/>
            <Setter Property="Height"       Value="0"/>
            <Setter Property="Width"        Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Rectangle Fill="Transparent"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Pouce (thumb) de la scrollbar -->
        <Style x:Key="ScrollBarThumb" TargetType="Thumb">
            <Setter Property="IsTabStop"    Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border Background="#FF6B35"
                                CornerRadius="4"
                                Margin="2,0"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Scrollbar verticale complète -->
        <Style TargetType="ScrollBar">
            <Setter Property="Width"      Value="10"/>
            <Setter Property="MinWidth"   Value="10"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="Transparent">
                            <Border Background="#222222"
                                    CornerRadius="4"
                                    Margin="1,0"/>
                            <Track x:Name="PART_Track"
                                   IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Style="{StaticResource ScrollBarRepeatButton}"
                                                  Command="ScrollBar.PageUpCommand"/>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource ScrollBarThumb}"/>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Style="{StaticResource ScrollBarRepeatButton}"
                                                  Command="ScrollBar.PageDownCommand"/>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ScrollViewer : masquer la scrollbar horizontale -->
        <Style TargetType="ScrollViewer">
            <Setter Property="HorizontalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="VerticalScrollBarVisibility"   Value="Auto"/>
        </Style>

    </Application.Resources>
</Application>
